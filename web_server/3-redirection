#!/usr/bin/env bash
# Configure Nginx to redirect /redirect_me to a YouTube video (301 Moved Permanently)

# Exit immediately if a command fails
set -e

# Update package index and install Nginx if not installed
sudo apt-get update -y
sudo apt-get install -y nginx

# Backup default Nginx config if not already backed up
if [ ! -f /etc/nginx/sites-available/default.bak ]; then
    sudo cp /etc/nginx/sites-available/default /etc/nginx/sites-available/default.bak
fi

# Add a 301 redirect for /redirect_me if not already present
if ! grep -q "location /redirect_me" /etc/nginx/sites-available/default; then
    sudo sed -i "/server_name _;/a \    location /redirect_me {\n        return 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n    }" /etc/nginx/sites-available/default
fi

# Test Nginx configuration
sudo nginx -t

# Reload Nginx to apply changes
sudo systemctl reload nginx

# Exit with success
exit 0
