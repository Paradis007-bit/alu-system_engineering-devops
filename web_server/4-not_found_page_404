#!/usr/bin/env bash
# Configure a custom 404 page with "Ceci n'est pas une page"

# Install Nginx if not installed
sudo apt-get update -y
sudo apt-get install -y nginx

# Create the custom 404 page
echo "Ceci n'est pas une page" | sudo tee /var/www/html/404.html

# Update Nginx config to use the custom 404 page
sudo sed -i '/server_name _;/a \    error_page 404 /404.html;\n    location = /404.html {\n        internal;\n    }' /etc/nginx/sites-available/default

# Test Nginx config
sudo nginx -t

# Reload Nginx to apply changes
sudo systemctl reload nginx
